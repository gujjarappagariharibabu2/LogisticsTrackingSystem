
@model List<LogisticsTrackingSystem.Models.User>

<h2>User Management</h2>

<table class="table table-bordered">

    <thead>

        <tr>

            <th>Id</th>

            <th>Username</th>

            <th>Email</th>

            <th>Role</th>

            <th>Actions</th>

        </tr>

    </thead>

    <tbody>

    @foreach (var user in Model)
    {
        <tr>

            <td>@user.Id</td>

            <td>@user.Username</td>

            <td>@user.Email</td>

            <td>@user.Role</td>

            <td>

                <a asp-action="EditUser"
                   asp-route-id="@user.Id"
                   class="btn btn-warning btn-sm">
                    Edit
                </a>

                <a asp-action="DeleteUser"
                   asp-route-id="@user.Id"
                   class="btn btn-danger btn-sm">
                    Delete
                </a>

            </td>

        </tr>
    }

    </tbody>

</table>