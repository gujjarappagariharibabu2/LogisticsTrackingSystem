
@model LogisticsTrackingSystem.Models.User

<h2>Edit User</h2>

<form asp-action="EditUser">

    <input type="hidden" asp-for="Id" />

    <div class="mb-3">

        <label>Username</label>

        <input asp-for="Username"
               class="form-control" />

    </div>

    <div class="mb-3">

        <label>Email</label>

        <input asp-for="Email"
               class="form-control" />

    </div>

    <div class="mb-3">

        <label>Role</label>

        <select asp-for="Role"
                class="form-control">

            <option value="Admin">
                Admin
            </option>

            <option value="Customer">
                Customer
            </option>

        </select>

    </div>

    <button type="submit"
            class="btn btn-primary">
        Save Changes
    </button>

</form>