@model LogisticsTrackingSystem.Models.Shipment

@{
    ViewData["Title"] = "Create Shipment";
}

<h2>Create Shipment</h2>

<form asp-action="Create" method="post">

    <div class="mb-3">

        <label class="form-label">
            Tracking Number
            <span asp-validation-for="TrackingNumber"
                  class="text-danger"></span>
        </label>

        <input asp-for="TrackingNumber"
               class="form-control" />

    </div>

    <div class="mb-3">

        <label class="form-label">
            Destination
            <span asp-validation-for="Destination"
                  class="text-danger"></span>
        </label>

        <input asp-for="Destination"
               class="form-control" />

    </div>

    <div class="form-check mb-3">

        <input asp-for="IsArchived"
               class="form-check-input" />

        <label class="form-check-label">
            Archived
        </label>

    </div>
    <div class="mb-3">

         <label class="form-label">
             Status
        </label>

        <select asp-for="Status"
                 class="form-control">

            <option value="Pending">
                  Pending
            </option>

             <option value="In Transit">
                 In Transit
            </option>

             <option value="Delivered">
                 Delivered
             </option>

            <option value="Cancelled">
                 Cancelled
            </option>

        </select>

    </div>

    <button type="submit"
            class="btn btn-primary">
        Save Shipment
    </button>

</form>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}