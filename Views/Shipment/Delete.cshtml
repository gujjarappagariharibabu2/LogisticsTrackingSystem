@model LogisticsTrackingSystem.Models.Shipment

@{
    ViewData["Title"] = "Delete Shipment";
}

<h2>Delete Shipment</h2>

<h4>
    Are you sure you want to delete this shipment?
</h4>

<hr />

<dl class="row">

    <dt class="col-sm-2">
        Tracking Number
    </dt>

    <dd class="col-sm-10">
        @Model.TrackingNumber
    </dd>

    <dt class="col-sm-2">
        Destination
    </dt>

    <dd class="col-sm-10">
        @Model.Destination
    </dd>

</dl>

<form asp-action="Delete" method="post">

    <input type="hidden" asp-for="Id" />

    <button type="submit"
            class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Active"
       class="btn btn-secondary">
        Cancel
    </a>

</form>